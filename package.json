{
	"name": "bun-playground",
	"private": true,
	"engines": {
		"bun": ">=1.3.9"
	},
	"packageManager": "bun@1.3.9",
	"scripts": {
		"modules:clean": "turbo run modules:clean && rm -rf node_modules",
		"modules:info": "find . -name \"node_modules\" -type d -prune | xargs du -chs",
		"bun:test": "turbo run test",
		"turbo:test": "turbo run test",
		"turbo:lint": "turbo run lint:check",
		"turbo:typecheck": "turbo tsc:check",
		"format:check": "biome format",
		"format:fix": "biome format --write",
		"ci:lint": "bun run --filter=* lint:check",
		"ci:test": "bun run --filter=* test",
		"ci:typecheck": "bun run --filter=* tsc:check"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.10",
		"@changesets/cli": "^2.29.8",
		"@types/bun": "^1.3.8",
		"commitlint": "^20.1.0",
		"is-ci": "^4.1.0",
		"turbo": "^2.6.3",
		"typescript": "^5.9.3"
	},
	"workspaces": [
		"applications/*",
		"domains/*",
		"kubernetes",
		"packages/*"
	]
}
