{
	"name": "@application/account",
	"version": "0.1.1",
	"private": true,
	"scripts": {
		"dev:app-server": "bun run --env-file-if-exists=.env --watch -- src/commands/start-api-server.ts",
		"db:generate": "bunx drizzle-kit generate --config=src/database/config.ts",
		"db:migrate": "bunx drizzle-kit migrate --config=src/database/config.ts",
		"db:seed": "bun src/database/commands/seed.ts",
		"db:truncate": "bun src/database/commands/truncate.ts",
		"lint:check": "biome lint .",
		"modules:clean": "rm -rf node_modules",
		"test": "bun test --pass-with-no-tests",
		"test:watch": "bun test --watch",
		"tsc:check": "tsc --noEmit",
		"tsc:check:watch": "tsc --noEmit --watch"
	},
	"dependencies": {
		"@domain/account": "workspace:",
		"@fastify/type-provider-typebox": "^5.2.0",
		"@package/core": "workspace:*",
		"@package/database": "workspace:*",
		"@package/drizzle": "workspace:*",
		"@package/errors": "workspace:*",
		"@package/fastify-plugins": "workspace:*",
		"@package/json-schema": "workspace:*",
		"@package/query-params": "workspace:*",
		"@package/query-params-serializer": "workspace:*",
		"@package/telemetry": "workspace:*",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.0",
		"es-toolkit": "^1.42.0",
		"fastify": "^5.7.4",
		"fastify-plugin": "^5.1.0",
		"pg": "^8.20.0"
	},
	"devDependencies": {
		"@types/pg": "^8.18.0"
	}
}
