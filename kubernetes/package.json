{
	"name": "kubernetes",
	"main": "main.ts",
	"types": "main.ts",
	"private": true,
	"scripts": {
		"debug": "bun src/main.ts",
		"tsc:check": "tsc --noEmit --skipLibCheck",
		"tsc:check:watch": "tsc --noEmit --watch --skipLibCheck",
		"lint:check": "biome lint .",
		"import-api-resources": "kubectl get crds -o yaml > crd.yaml;pnpm cdk8s import --output imports;rm crd.yaml",
		"generate-manifests": "cdk8s synth --output manifests --check-upgrade=false"
	},
	"devDependencies": {
		"cdk8s": "^2.70.33",
		"cdk8s-cli": "^2.200.150",
		"cdk8s-plus-33": "^2.4.10",
		"constructs": "^10.4.4",
		"es-toolkit": "^1.43.0"
	}
}
